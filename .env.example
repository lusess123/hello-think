# GitHub OAuth credentials for the assistant example.
# Create a GitHub OAuth App at https://github.com/settings/developers
# and fill in the values below before running `npm start`.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare AI Gateway BYOK configuration.
# Keep real values in an ignored local env file or inject them at process start.
AI_GATEWAY_BASE_URL=
AI_GATEWAY_TOKEN=
AI_GATEWAY_PROVIDER_ALIAS=default
LLM_DEFAULT_MODEL=deepseek-v4-flash

# Cross-origin production is injected by GitHub Actions. Leave blank for the
# integrated local Vite server, where the browser and API share one origin.
# VITE_API_ORIGIN=https://dsl-api.zyking.xyz

# Independent high-entropy secret for short-lived Agent WebSocket tokens.
# Configure the production value as the WS_TOKEN_SECRET Actions/Worker secret.
WS_TOKEN_SECRET=

# Local loopback development uses the tracked `DEV_USER=local` Wrangler var.
# It is ignored on every deployed/non-loopback hostname.

# GitHub App story versioning. Public identifiers live in wrangler.jsonc.
# `npm start` reads the PEM from the repository-local default below; override
# this only when your downloaded key lives somewhere else.
# STORY_GITHUB_PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem

# The editor allowlist is a public Wrangler var, not a dotenv secret. Configure
# comma-separated immutable numeric IDs in `wrangler.jsonc`.
